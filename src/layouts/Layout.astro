---
import "../styles/global.css";
import { SEO } from "astro-seo";
import { getImagePath } from "astro-opengraph-images";

interface Props {
  title: string;
  description: string;
  iconUrl: string;
  /** Site/app name for og:site_name. Defaults to "flinky.me". */
  siteName?: string;
}

const { title, description, iconUrl, siteName = "flinky.me" } = Astro.props;
const site = Astro.site ?? "https://flinky.me";
const canonicalUrl = new URL(Astro.url.pathname, site);
const themeColor = "#007aff";
const ogImageUrl = getImagePath({ url: Astro.url, site: Astro.site });
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      canonical={canonicalUrl.href}
      charset="UTF-8"
      openGraph={{
        basic: {
          title,
          type: "website",
          image: ogImageUrl,
          url: canonicalUrl.href,
        },
        optional: {
          description,
          siteName,
        },
        image: {
          alt: description,
        },
      }}
      twitter={{
        card: "summary_large_image",
        title,
        description,
        image: ogImageUrl,
      }}
      extend={{
        link: [
          { rel: "icon", type: "image/png", href: iconUrl },
          { rel: "apple-touch-icon", href: iconUrl },
        ],
        meta: [
          { name: "viewport", content: "width=device-width, initial-scale=1.0" },
          { name: "theme-color", content: themeColor },
          { name: "generator", content: Astro.generator },
        ],
      }}
    />

    <slot name="head" />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        if (
          stored === "dark" ||
          (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <script defer src="https://cloud.umami.is/script.js" data-website-id="6efde0e5-15be-488a-a3c0-32402cffc587"></script>
  </head>
  <body class="min-h-screen">
    <a
      href="#main-content"
      class="skip-link"
    >
      Skip to main content
    </a>
    <slot />
  </body>
</html>
