---
import type { FAQItem } from "@lib/types";

interface Props {
  faqs: FAQItem[];
}

const { faqs } = Astro.props;
---

{
  faqs.length > 0 && (
    <section class="px-4 py-12 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-heading mb-8 text-center">FAQ</h2>
        <div class="space-y-4">
          {faqs.map((faq, i) => (
            <details class="card-base group" data-faq={i}>
              <summary class="flex cursor-pointer items-center justify-between font-semibold list-none">
                {faq.question}
                <svg
                  class="h-5 w-5 flex-shrink-0 text-text-secondary transition-transform duration-200 group-open:rotate-180 dark:text-text-secondary-dark"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </summary>
              <p class="mt-3 text-text-secondary dark:text-text-secondary-dark">
                {faq.answer}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )
}
