---
---

<div class="flex items-center gap-1 rounded-full bg-surface-secondary p-1 dark:bg-surface-secondary-dark">
  <button data-theme-set="light" class="theme-btn rounded-full p-2 transition-colors" aria-label="Light mode">
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5" />
      <line x1="12" y1="1" x2="12" y2="3" />
      <line x1="12" y1="21" x2="12" y2="23" />
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
      <line x1="1" y1="12" x2="3" y2="12" />
      <line x1="21" y1="12" x2="23" y2="12" />
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
    </svg>
  </button>
  <button data-theme-set="system" class="theme-btn rounded-full p-2 transition-colors" aria-label="System theme">
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
      <line x1="8" y1="21" x2="16" y2="21" />
      <line x1="12" y1="17" x2="12" y2="21" />
    </svg>
  </button>
  <button data-theme-set="dark" class="theme-btn rounded-full p-2 transition-colors" aria-label="Dark mode">
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </button>
</div>

<style>
  .theme-btn {
    color: var(--color-text-secondary);
    background: transparent;
    border: none;
    cursor: pointer;
  }
  .theme-btn.active {
    background: var(--color-surface);
    color: var(--color-text-primary);
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.1);
  }
  .dark .theme-btn.active {
    background: var(--color-surface-dark);
    color: var(--color-text-primary-dark);
  }
</style>

<script is:inline>
  (function () {
    function getTheme() {
      return localStorage.getItem('theme') || 'system';
    }

    function applyTheme(theme) {
      var isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
      document.documentElement.classList.toggle('dark', isDark);
      localStorage.setItem('theme', theme);
      updateButtons(theme);
    }

    function updateButtons(theme) {
      document.querySelectorAll('[data-theme-set]').forEach(function (btn) {
        btn.classList.toggle('active', btn.getAttribute('data-theme-set') === theme);
      });
    }

    updateButtons(getTheme());

    document.querySelectorAll('[data-theme-set]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        applyTheme(this.getAttribute('data-theme-set'));
      });
    });

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function () {
      if (getTheme() === 'system') {
        applyTheme('system');
      }
    });
  })();
</script>
