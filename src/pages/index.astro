---
import About from "@components/sections/About.astro";
import FAQ from "@components/sections/FAQ.astro";
import Features from "@components/sections/Features.astro";
import Footer from "@components/sections/Footer.astro";
import Hero from "@components/sections/Hero.astro";
import Screenshots from "@components/sections/Screenshots.astro";
import WhatsNew from "@components/sections/WhatsNew.astro";
import BackToTop from "@components/ui/BackToTop.astro";
import { appConfig } from "@config/app.config";
import Layout from "@layouts/Layout.astro";
import { getArtworkUrl } from "@lib/api";
import { fetchAppData } from "@lib/fetchAppData";
const app = await fetchAppData();
const iconUrl = getArtworkUrl(app, 512);
const shortDescription = app.description.split("\n")[0];
const siteUrl = Astro.site?.toString() ?? "https://flinky.me";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: app.name,
  description: shortDescription,
  image: iconUrl,
  applicationCategory: "UtilitiesApplication",
  operatingSystem: "iOS",
  offers: {
    "@type": "Offer",
    price: app.price,
    priceCurrency: "USD",
  },
  aggregateRating:
    app.userRating.count > 0
      ? {
          "@type": "AggregateRating",
          ratingValue: app.userRating.average,
          ratingCount: app.userRating.count,
          bestRating: 5,
        }
      : undefined,
  downloadUrl: app.storeUrl,
  url: canonicalUrl,
};
---

<Layout
  title={`${app.name} — ${shortDescription}`}
  description={shortDescription}
  iconUrl={iconUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <main>
    <Hero app={app} iconUrl={iconUrl} shortDescription={shortDescription} />
    <Screenshots screenshots={app.screenshots} appName={app.name} />
    <Features features={appConfig.features} />
    <About app={app} />
    <WhatsNew app={app} />
    <FAQ faqs={appConfig.faqs} />
  </main>
  <Footer app={app} config={appConfig} />
  <BackToTop />
</Layout>
